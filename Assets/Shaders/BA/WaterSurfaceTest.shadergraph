{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "2abf20c4c16946948854ba363e24c5c1",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "SceneDepthToWorldPos (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1556.5,
            "y": 1577.5,
            "width": 293.5,
            "height": 302.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "f816f21dcb2a4443b85432ea57aab9b0"
        },
        {
            "m_Id": "2a158df5ad3c422797c745bee689d119"
        },
        {
            "m_Id": "31d0e1ba11074e72a54c7cae065bb19d"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "SceneDepthToWorldPos",
    "m_FunctionSource": "",
    "m_FunctionBody": "    float4 clipPos = float4(uv * 2 - 1, depth, 1);\r\n    float4 viewPos = mul(unity_CameraInvProjection, clipPos);\r\n    viewPos.xyz /= viewPos.w;\r\n    worldPos = mul(unity_CameraToWorld, viewPos).xyz;"
}

